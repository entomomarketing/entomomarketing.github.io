  <script>
    // ===== DIA DEMO ANIMATION =====
    (function() {
      const question = "what's our time-to-productivity for new hires this quarter?";
      const dataSource = ["recruitment pipeline", "onboarding metrics", "payroll data", "attrition trends"];
      const agents = ["profilecraft", "flowgen", "insight360"];

      function runDiaLoop() {
        const chatEl = document.getElementById('pdiaChat');
        const inputEl = document.getElementById('pdiaInput');

        // Reset
        chatEl.innerHTML = '';
        inputEl.textContent = '';

        // 1. Greeting (400ms pause)
        setTimeout(() => {
          const greetMsg = document.createElement('div');
          greetMsg.className = 'dia-msg show';
          greetMsg.innerHTML = `<div class="dia-greeting">hi sharon, here's your onboarding analysis.</div>`;
          chatEl.appendChild(greetMsg);
        }, 400);

        // 2. Question typing (character by character, 22ms/char)
        let charIndex = 0;
        const typeInterval = setInterval(() => {
          inputEl.textContent = question.substring(0, charIndex + 1);
          charIndex++;
          if (charIndex >= question.length) {
            clearInterval(typeInterval);
            setTimeout(() => sendQuestion(), 300);
          }
        }, 22);

        function sendQuestion() {
          // User question bubble
          const userMsg = document.createElement('div');
          userMsg.className = 'dia-msg show dia-user-q';
          userMsg.innerHTML = `<span>${question}</span>`;
          chatEl.appendChild(userMsg);
          inputEl.textContent = '';

          // Data source phase
          setTimeout(() => {
            const dataMsg = document.createElement('div');
            dataMsg.className = 'dia-msg show dia-phase';
            let dataHTML = `<div class="dia-phase-dot foundation">📊</div><div class="dia-phase-body">`;
            dataHTML += `<div class="dia-phase-label">querying data</div><div class="dia-phase-pills">`;
            dataSource.forEach(d => {
              dataHTML += `<span class="dia-phase-pill dark">${d}</span>`;
            });
            dataHTML += `</div></div>`;
            dataMsg.innerHTML = dataHTML;
            chatEl.appendChild(dataMsg);
          }, 800);

          // Agent phase
          setTimeout(() => {
            const agentMsg = document.createElement('div');
            agentMsg.className = 'dia-msg show dia-phase';
            let agentHTML = `<div class="dia-phase-dot agents">🤖</div><div class="dia-phase-body">`;
            agentHTML += `<div class="dia-phase-label">agents analysing</div><div class="dia-phase-pills">`;
            agents.forEach(a => {
              agentHTML += `<span class="dia-phase-pill blue">${a}</span>`;
            });
            agentHTML += `</div></div>`;
            agentMsg.innerHTML = agentHTML;
            chatEl.appendChild(agentMsg);
          }, 1400);

          // Collapse previous messages
          setTimeout(() => {
            const allMsgs = chatEl.querySelectorAll('.dia-msg');
            allMsgs.forEach((msg, idx) => {
              if (idx < allMsgs.length - 2) {
                msg.classList.remove('show');
              }
            });
          }, 2000);

          // Show outcome
          setTimeout(() => {
            chatEl.innerHTML = `
              <div class="dia-msg show">
                <div class="dia-greeting">hi sharon, here's your onboarding analysis.</div>
              </div>
              <div class="dia-msg show">
                <div class="dia-outcome">
                  <div class="dia-outcome-label">new hire productivity assessment</div>
                  <div class="dia-outcome-row">
                    <div class="dia-outcome-score">58</div>
                    <div class="dia-outcome-badge">📍 days avg</div>
                  </div>
                  <div class="dia-outcome-divider"></div>
                  <div class="dia-outcome-detail">average time-to-productivity is 58 days — 12 days above benchmark. engineering onboarding taking 74 days (it provisioning delay). sales onboarding at 45 days (best in class). 23% of new hires report unclear role expectations in week-1 survey. recommend: automate it provisioning in engineering, implement structured week-1 role clarity sessions.</div>
                </div>
              </div>
            `;
          }, 2500);

          // Reset loop after delay
          setTimeout(runDiaLoop, 6000);
        }
      }

      runDiaLoop();
    })();

    // ===== WORKWISE DEMO ANIMATION =====
    (function() {
      const question = "set up onboarding workflow for 15 new hires starting april 14";

      function runWwLoop() {
        const panelGreet = document.getElementById('pwwPanelGreet');
        const panelChat = document.getElementById('pwwPanelChat');
        const inputEl = document.getElementById('pwwInput');
        const userQEl = document.getElementById('pwwUserQ');
        const responseArea = document.getElementById('pwwResponseArea');
        const subThink = document.getElementById('pwwSubThink');
        const subAssemble = document.getElementById('pwwSubAssemble');
        const subOutput = document.getElementById('pwwSubOutput');

        // Reset
        panelGreet.classList.add('active');
        panelChat.classList.remove('active');
        inputEl.textContent = '';
        userQEl.innerHTML = '';

        // 1. Greeting visible
        setTimeout(() => {
          // 2. Question typing
          let charIndex = 0;
          const typeInterval = setInterval(() => {
            inputEl.textContent = question.substring(0, charIndex + 1);
            charIndex++;
            if (charIndex >= question.length) {
              clearInterval(typeInterval);
              setTimeout(() => sendQuestion(), 400);
            }
          }, 18);
        }, 600);

        function sendQuestion() {
          // Switch panels
          panelGreet.classList.remove('active');
          panelChat.classList.add('active');

          // User question
          setTimeout(() => {
            userQEl.innerHTML = `<span>${question}</span>`;
          }, 200);

          // Thinking sub
          setTimeout(() => {
            subThink.classList.add('active');
          }, 600);

          // Assemble agents
          setTimeout(() => {
            subThink.classList.remove('active');
            subAssemble.classList.add('active');
          }, 2000);

          // Output
          setTimeout(() => {
            subAssemble.classList.remove('active');
            subOutput.classList.add('active');
          }, 3200);

          // Reset
          setTimeout(runWwLoop, 6500);
        }
      }

      runWwLoop();
    })();

    // ===== COACH DEMO ANIMATION =====
    (function() {
      const question = "how many leave days do i have left and can i take next friday off?";

      function runCoachLoop() {
        const panelGreet = document.getElementById('pcoachPanelGreet');
        const panelChat = document.getElementById('pcoachPanelChat');
        const inputEl = document.getElementById('pcoachInput');
        const userQEl = document.getElementById('pcoachUserQ');
        const responseArea = document.getElementById('pcoachResponseArea');
        const subThink = document.getElementById('pcoachSubThink');
        const subResponse = document.getElementById('pcoachSubResponse');

        // Reset
        panelGreet.classList.add('active');
        panelChat.classList.remove('active');
        inputEl.textContent = '';
        userQEl.innerHTML = '';

        // 1. Greeting visible
        setTimeout(() => {
          // 2. Question typing
          let charIndex = 0;
          const typeInterval = setInterval(() => {
            inputEl.textContent = question.substring(0, charIndex + 1);
            charIndex++;
            if (charIndex >= question.length) {
              clearInterval(typeInterval);
              setTimeout(() => sendQuestion(), 400);
            }
          }, 18);
        }, 600);

        function sendQuestion() {
          // Switch panels
          panelGreet.classList.remove('active');
          panelChat.classList.add('active');

          // User question
          setTimeout(() => {
            userQEl.innerHTML = `<span>${question}</span>`;
          }, 200);

          // Thinking sub
          setTimeout(() => {
            subThink.classList.add('active');
          }, 600);

          // Response
          setTimeout(() => {
            subThink.classList.remove('active');
            subResponse.classList.add('active');
          }, 2200);

          // Reset
          setTimeout(runCoachLoop, 6000);
        }
      }

      runCoachLoop();
    })();

    // ===== FEATURES TAB SWITCHING =====
    document.querySelectorAll('.features-tab').forEach(tab => {
      tab.addEventListener('click', function() {
        const tabId = this.getAttribute('data-tab');

        document.querySelectorAll('.features-tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.features-grid').forEach(grid => grid.style.display = 'none');

        this.classList.add('active');
        document.getElementById('features' + tabId.charAt(0).toUpperCase() + tabId.slice(1)).style.display = 'grid';
      });
    });
  </script>
</body>
</html>
