  <!-- ===== HERO ===== -->
  <section class="sol-hero">
    <div class="container">
      <div class="sol-hero-content">
        <div class="sol-breadcrumb">
          <a href="/">solutions</a>
          <span>/</span>
          <span>hire to retire</span>
        </div>
        <h1>simplify the entire <mark>employee</mark> journey</h1>
        <p class="sol-hero-sub">hire to retire shouldn't feel like a dozen disconnected tools. unify recruitment, onboarding, payroll, attendance, and exit in one seamless experience.</p>
        <button class="btn-primary">get started →</button>
      </div>
    </div>
  </section>

  <!-- ===== LEADERS SECTION (DIA DEMO) ===== -->
  <section class="persona-sec sec-leaders">
    <div class="container">
      <div class="persona-sec-inner">
        <div class="persona-sec-text">
